{
    "$schema": "https://opencode.ai/config.json",
    "theme": "catppuccin",
    "model": "github-copilot/claude-sonnet-4.5",
    "autoupdate": true,
    "mcp": {
        "azure-devops": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@azure-devops/mcp",
                "teamnavara",
                "-d",
                "core",
                "work",
                "repositories",
                "pipelines"
            ],
            "environment": {
                "AZURE_DEVOPS_ORG": "teamnavara",
                "AZURE_DEVOPS_PAT": "${AZURE_DEVOPS_PAT}"
            },
            "enabled": true,
            "timeout": 10000
        },
        "Framelink Figma MCP": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "figma-developer-mcp",
                "--figma-api-key=${FIGMA_API_KEY}",
                "--stdio"
            ],
            "enabled": true,
        },
    }
}
